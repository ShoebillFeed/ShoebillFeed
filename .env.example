# Database
POSTGRES_USER=phoenix
POSTGRES_PASSWORD=changeme
POSTGRES_DB=phoenix

# LLM — ordered comma-separated list; first = primary, rest = fallbacks
# Examples:
#   LLM_PROVIDERS=anthropic            # Anthropic only
#   LLM_PROVIDERS=ollama               # Ollama only
#   LLM_PROVIDERS=anthropic,ollama     # Anthropic with Ollama fallback
#   LLM_PROVIDERS=ollama,anthropic     # Ollama with Anthropic fallback
LLM_PROVIDERS=ollama

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# Set OLLAMA_BASE_URL to a remote host to use Ollama on another machine
# e.g. http://192.168.1.10:11434  or  http://my-gpu-server:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=120               # seconds; increase for remote/slow hosts

# How long to wait for an Anthropic batch before cancelling and falling back to sync
LLM_BATCH_MAX_WAIT_MINUTES=10

# Reddit (https://www.reddit.com/prefs/apps)
# Create a "personal use script" app to get client ID and secret.
# Script-type apps also require your Reddit username + password for token exchange.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ShoebillFeed/1.0
REDDIT_USERNAME=
REDDIT_PASSWORD=

# YouTube Data API v3 (https://console.cloud.google.com/)
YOUTUBE_API_KEY=

# Auth — generate a strong random secret: openssl rand -hex 32
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Web Push / VAPID keys (required for push notifications)
# Generate with: python -c "from pywebpush import Vapid; v=Vapid(); v.generate_keys(); print('VAPID_PRIVATE_KEY='+v.private_key); print('VAPID_PUBLIC_KEY='+v.public_key)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost
